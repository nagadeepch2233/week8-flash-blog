/* Basic styling for the blog */
body {
    padding-top: 70px;
    font-family: Arial, sans-serif;
    background-color: #f8f9fa;
}

.navbar-brand {
    font-weight: bold;
    font-size: 1.5rem;
}

.card {
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

footer {
    text-align: center;
    margin-top: 50px;
    padding: 20px 0;
    background-color: #343a40;
    color: white;
}
